<% layout('layouts/boilerplate') -%>

<!-- SideNavBar and Mobile TopBar (Partials) -->
<%- include('partials/sidebar') %>

<div class="flex h-screen overflow-hidden w-full">
    <!-- Main Content -->
    <main class="flex-grow ml-0 md:ml-64 pt-24 md:pt-8 pb-24 px-margin-mobile md:px-container-padding max-w-[1440px] mx-auto overflow-y-auto relative">
        
        <!-- Page Header -->
        <div class="mb-section-gap">
            <h1 class="font-display-lg text-display-lg text-on-background mb-2">Savings Goals</h1>
            <p class="font-body-lg text-body-lg text-on-surface-variant">Set aside funds, monitor milestones, and grow your wealth securely.</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter w-full">
            <!-- Add Savings Goal Card (Left Column) -->
            <div class="lg:col-span-4 flex flex-col gap-gutter w-full">
                <div class="glass-card rounded-xl p-container-padding">
                    <h2 class="font-title-md text-title-md text-on-surface mb-6 flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">savings</span>
                        New Savings Goal
                    </h2>
                    
                    <form action="/savings" method="POST" class="flex flex-col gap-4">
                        <!-- Goal Title -->
                        <div>
                            <label class="font-label-md text-label-md text-on-surface-variant block mb-1 uppercase tracking-wider" for="title">Goal Name</label>
                            <input class="w-full input-premium rounded-lg px-4 py-3 font-body-lg text-body-lg text-on-surface placeholder-outline focus:ring-0" id="title" name="title" placeholder="e.g. Dream House Fund" required type="text"/>
                        </div>

                        <!-- Target Amount -->
                        <div>
                            <label class="font-label-md text-label-md text-on-surface-variant block mb-1 uppercase tracking-wider" for="targetAmount">Target Amount (USD)</label>
                            <div class="relative">
                                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant material-symbols-outlined" style="font-size: 18px;">attach_money</span>
                                <input class="w-full input-premium rounded-lg pl-10 pr-4 py-3 font-body-lg text-body-lg text-on-surface focus:ring-0" id="targetAmount" name="targetAmount" placeholder="0.00" step="0.01" min="1" required type="number"/>
                            </div>
                        </div>

                        <!-- Target Date -->
                        <div>
                            <label class="font-label-md text-label-md text-on-surface-variant block mb-1 uppercase tracking-wider" for="targetDate">Target Date (Optional)</label>
                            <input class="w-full input-premium rounded-lg px-4 py-3 font-body-lg text-body-lg text-on-surface focus:ring-0" id="targetDate" name="targetDate" type="date"/>
                        </div>

                        <!-- Submit Button -->
                        <button class="btn-primary text-white font-title-md text-body-lg rounded-lg py-4 mt-4 flex items-center justify-center gap-2 transition-all w-full" type="submit">
                            <span class="material-symbols-outlined text-sm">add</span>
                            Create Goal
                        </button>
                    </form>
                </div>
            </div>

            <!-- Savings Goals List (Right Column) -->
            <div class="lg:col-span-8 flex flex-col gap-gutter w-full">
                <% if (typeof goals === 'undefined' || goals.length === 0) { %>
                    <div class="glass-card rounded-xl p-12 text-center flex flex-col items-center justify-center h-full">
                        <div class="w-16 h-16 rounded-full bg-primary-container/20 flex items-center justify-center text-primary-container mb-4">
                            <span class="material-symbols-outlined text-[36px]" style="font-variation-settings: 'FILL' 1;">savings</span>
                        </div>
                        <h3 class="font-title-md text-title-md text-on-background mb-2">No Savings Goals Set</h3>
                        <p class="font-body-lg text-body-lg text-on-surface-variant max-w-sm">Start allocating budgets towards your future milestones by creating your first target goal.</p>
                    </div>
                <% } else { %>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-gutter">
                        <% goals.forEach(goal => { %>
                            <% 
                                const percent = Math.min(100, Math.round((goal.currentAmount / goal.targetAmount) * 100));
                                let colorClass = 'bg-primary';
                                if (percent >= 100) colorClass = 'bg-green-500';
                                else if (percent >= 75) colorClass = 'bg-orange-400';
                                else if (percent >= 50) colorClass = 'bg-primary-container';
                            %>
                            <div class="glass-card rounded-xl p-6 flex flex-col justify-between tilt-card" style="box-shadow: 0 10px 30px rgba(184, 134, 11, 0.05);">
                                <!-- Top Row -->
                                <div>
                                    <div class="flex justify-between items-start mb-4">
                                        <div class="w-10 h-10 rounded-full bg-primary-container/10 flex items-center justify-center text-primary">
                                            <span class="material-symbols-outlined">payments</span>
                                        </div>
                                        <form action="/savings/<%= goal._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Are you sure you want to delete this goal?')">
                                            <button class="text-on-surface-variant hover:text-error transition-colors p-1" type="submit">
                                                <span class="material-symbols-outlined text-[20px]">delete</span>
                                            </button>
                                        </form>
                                    </div>

                                    <!-- Goal Details -->
                                    <h3 class="font-title-md text-title-md text-on-background mb-1"><%= goal.title %></h3>
                                    <% if (goal.targetDate) { %>
                                        <p class="text-xs text-on-surface-variant mb-4 flex items-center gap-1">
                                            <span class="material-symbols-outlined text-[14px]">calendar_today</span>
                                            Target Date: <%= new Date(goal.targetDate).toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' }) %>
                                        </p>
                                    <% } else { %>
                                        <p class="text-xs text-on-surface-variant mb-4">Ongoing Goal</p>
                                    <% } %>

                                    <!-- Progress Tracker -->
                                    <div class="flex justify-between items-end mb-2">
                                        <div>
                                            <span class="text-xs text-on-surface-variant block uppercase font-bold tracking-wider">Saved</span>
                                            <span class="font-headline-lg-mobile text-headline-lg-mobile text-on-background font-bold">$<%= goal.currentAmount.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 }) %></span>
                                        </div>
                                        <div class="text-right">
                                            <span class="text-xs text-on-surface-variant block uppercase font-bold tracking-wider">Target</span>
                                            <span class="font-body-lg text-body-lg text-on-surface-variant">$<%= goal.targetAmount.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 }) %></span>
                                        </div>
                                    </div>

                                    <!-- Progress Bar -->
                                    <div class="w-full bg-surface-container rounded-full h-3 mb-6 overflow-hidden">
                                        <div class="h-full <%= colorClass %> rounded-full transition-all duration-500" style="width: <%= percent %>%"></div>
                                    </div>

                                    <!-- Milestones list -->
                                    <div class="mb-6">
                                        <span class="text-xs text-on-surface-variant block uppercase font-bold tracking-wider mb-3">Milestone Progress</span>
                                        <div class="grid grid-cols-4 gap-1.5 text-center">
                                            <% goal.milestones.forEach(milestone => { %>
                                                <div class="flex flex-col items-center">
                                                    <div class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold transition-all duration-300 <%= milestone.reached ? 'bg-primary text-white shadow-md' : 'bg-surface-container text-on-surface-variant' %>">
                                                        <%= milestone.percent %>%
                                                    </div>
                                                    <% if (milestone.reached) { %>
                                                        <span class="text-[9px] text-green-600 mt-1 font-semibold">Done</span>
                                                    <% } else { %>
                                                        <span class="text-[9px] text-on-surface-variant mt-1">Locked</span>
                                                    <% } %>
                                                </div>
                                            <% }) %>
                                        </div>
                                    </div>
                                </div>

                                <!-- Action Deposit Section -->
                                <div class="pt-4 border-t border-outline-variant/10">
                                    <form action="/savings/<%= goal._id %>/deposit" method="POST" class="flex gap-2">
                                        <div class="relative flex-grow">
                                            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant material-symbols-outlined text-[18px]">attach_money</span>
                                            <input class="w-full input-premium rounded-lg pl-8 pr-2 py-2 text-sm focus:ring-0" name="amount" placeholder="Deposit" step="0.01" min="0.01" required type="number"/>
                                        </div>
                                        <button class="btn-primary text-white text-xs font-semibold px-4 py-2 rounded-lg flex items-center gap-1 hover:shadow-md transition-all active:translate-y-0.5" type="submit">
                                            <span class="material-symbols-outlined text-[14px]">save_alt</span>
                                            Add
                                        </button>
                                    </form>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>
        </div>
    </main>
</div>
